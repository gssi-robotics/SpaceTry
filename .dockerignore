# Markdown files
**/*.md

# Images
**/*.png
**/*.jpeg
**/*.jpg
**/*.gif
**/*.svg

# Runtime Gazebo model textures must remain in the Docker build context.
!src/spacetry_models/models/**/materials/**/*.png
!src/spacetry_models/models/**/materials/**/*.jpeg
!src/spacetry_models/models/**/materials/**/*.jpg

# Git
.git
.gitignore

# Docker
.dockerignore

# Log files
log/
logs/
**/*.log
**/*.mcap

# Python cache
**/__pycache__/
**/*.pyc

# Templates
**/*.template

# LLM agents
skills/
.codex
.agents/

# Build artifacts (already excluded via Dockerfile RUN rm -rf)
# but good to be explicit
build/
install/

# IDEs
.editorconfig
.vscode/
.idea/
**/*.swp
**/*.swo

# CI/CD
.github/

# macOS
.DS_Store
