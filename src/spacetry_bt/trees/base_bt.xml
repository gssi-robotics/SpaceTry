<root BTCPP_format="4" main_tree_to_execute="Main">
  <BehaviorTree ID="Main">
    <Sequence name="MissionSequence">
      <SetGoal waypoint="science_rock" goal="{goal}" />

      <NavigateWithAvoidance goal="{goal}"
                             v_lin="1.6"
                             min_lin="0.25"
                             v_ang="1.4"
                             dist_tol="1.5"
                             kp_yaw="1.4"
                             yaw_slow_deg="20.0"
                             odom_topic="/mobile_base_controller/odom"
                             scan_topic="/scan"
                             obstacle_front_topic="/obstacle/front"
                             obstacle_left_topic="/obstacle/left"
                             obstacle_right_topic="/obstacle/right"
                             obstacle_threshold_m="9.0"
                             odom_timeout_s="15.0"
                             reverse_speed="0.8"
                             reverse_seconds="1.0"
                             avoid_arc_seconds="1.4"
                             memory_seconds="3.0" />

      <AlignToGoal goal="{goal}"
                   v_lin="0.0"
                   min_lin="0.0"
                   v_ang="1.0"
                   yaw_tol_deg="10" />

      <StopAndObserve seconds="3.0" />
      <LogMessage message="Science rock reached" />
    </Sequence>
  </BehaviorTree>
</root>
