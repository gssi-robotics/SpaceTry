            "parent_reqid": "",
            "project": "SpaceTry",
            "rationale": "When an obstacle is detected within the safety threshold (1.0 m), the rover must immediately issue a stop command.\n",
            "comments": "",
            "fulltext": "if obstacle_too_close the rover shall immediately satisfy cmd_move_stop",
            "status": "",
            "semantics": {
                "type": "nasa",
                "scope": {
                    "type": "null"
                },
                "condition": "regular",
                "timing": "immediately",
                "response": "satisfaction",
                "variables": [
                    "obstacle_too_close",
                    "cmd_move_stop"
                ],
                "component_name": "rover",
                "ptExpanded": "",
                "pt": ""
            }
        },
        {
